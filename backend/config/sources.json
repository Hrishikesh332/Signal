      "id": "source-market-techcrunch-ai",
      "name": "TechCrunch AI",
      "category": "reputation_intelligence",
      "company_id": "market-tech",
      "company_name": "Tech Market",
      "target_url": "https://techcrunch.com/tag/ai/",
      "goal": "Visit the public TechCrunch AI tag page and extract up to 5 latest visible tech market articles. Return only tech market signals. For each article, extract title, summary, published timestamp, article URL, signal type, market category, severity, mentioned companies when explicit, and explicit regions when explicit. Do not invent companies or regions.",
      "browser_profile": "lite",
      "schedule": {
        "interval_minutes": 360
      },
      "proxy_config": {
        "enabled": true,
        "country_code": "US"
      },
      "use_vault": false,
      "credential_item_ids": [],
      "sector": "tech",
      "geography": "global",
      "output_schema": {
        "type": "object",
        "required": [
          "captured_at",
          "articles",
          "metrics",
          "map_points"
        ],
        "properties": {
          "captured_at": {
            "type": "string"
          },
          "articles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "title",
                "summary",
                "published_at",
                "article_url",
                "signal_type",
                "market_category",
                "severity"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "published_at": {
                  "type": "string"
                },
                "article_url": {
                  "type": "string"
                },
                "signal_type": {
                  "type": "string"
                },
                "market_category": {
                  "type": "string"
                },
                "severity": {
                  "type": "string"
                },
                "companies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "regions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "metrics": {
            "type": "object",
            "required": [
              "story_count"
            ],
            "properties": {
              "story_count": {
                "type": "number"
              }
            }
          },
          "map_points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "latitude",
                "longitude",
                "entity_name",
                "signal_type",
                "severity",
                "timestamp",
                "explanation"
              ],
              "properties": {
                "latitude": {
                  "type": "number"
                },
                "longitude": {
                  "type": "number"
                },
                "entity_name": {
                  "type": "string"
                },
                "signal_type": {
                  "type": "string"
                },
                "severity": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string"
                },
                "explanation": {
                  "type": "string"
                },
                "cluster_key": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "stop_conditions": [
        "Stop after 5 visible articles are extracted.",
        "Stop when the first page has been fully parsed and no new article cards remain.",
        "Stop after two consecutive page parsing failures."
      ],
      "error_handling": {
        "timeout": {
          "action": "retry",
          "max_retries": 2,
          "emit_status": "failed"
