FLASK_APP=backend/app.py
FLASK_DEBUG=1
MARKET_MONITOR_APP_NAME=AI Market Sentry Platform
MARKET_MONITOR_SOURCE_CONFIG_FILE=backend/config/sources.json
MARKET_MONITOR_SNAPSHOT_STORE_DIR=backend/data/snapshots
PRODUCT_VIABILITY_MAX_IMAGES=4
PRODUCT_VIABILITY_MAX_IMAGE_BYTES=5242880
TINYFISH_BASE_URL=https://agent.tinyfish.ai
